# Frontend (Vite) — copy to `.env` in the project root. Only variables prefixed
# with VITE_ are exposed to the browser.
VITE_USE_LOCAL_AI=true
VITE_AI_API_URL=http://127.0.0.1:8000/generate-chant

# Show AI fetch / validation diagnostics in the UI after each generate (testing).
VITE_DEBUG_AI=false

# Backend (set in the shell when you start uvicorn, not in this file)
# CHEER_MODEL_PATH=path/to/models--Ocean82--lyrics-generator
# CREATIVE_MODEL_PATH=path/to/Llama-Song-Stream-3B-Instruct-*.gguf
